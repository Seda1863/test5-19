<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 1. ÇEK TAKİP PANELİ -->
    <record id="dashboard_cek_takip" model="spreadsheet.dashboard">
        <field name="name">Çek Takip Paneli</field>
        <field name="spreadsheet_binary_data" type="base64" file="spreadsheet_edonusum/data/files/cek_takip_dashboard.json"/>
        <field name="dashboard_group_id" ref="spreadsheet_edonusum.spreadsheet_dashboard_group_edonusum"/>
        <field name="group_ids" eval="[Command.link(ref('account.group_account_readonly')), Command.link(ref('account.group_account_invoice'))]"/>
        <field name="sequence">10</field>
        <field name="is_published">True</field>
    </record>

