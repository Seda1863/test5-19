<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_skyplanner_simulate_wizard_form" model="ir.ui.view">
        <field name="name">skyplanner.simulate.wizard.form</field>
        <field name="model">skyplanner.simulate.wizard</field>
        <field name="arch" type="xml">
            <form string="APS Plan Preview">
                <sheet>
                    <group invisible="state != 'error'">
                        <field name="error_message" widget="text" readonly="1"/>
                    </group>
                    <group invisible="state != 'done'">
                        <field name="result_html" nolabel="1" readonly="1"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Load Plan"
                            name="action_load_plan"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button string="Close" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
