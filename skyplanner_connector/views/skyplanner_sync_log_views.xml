<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_skyplanner_sync_log_list" model="ir.ui.view">
        <field name="name">skyplanner.sync.log.list</field>
        <field name="model">skyplanner.sync.log</field>
        <field name="arch" type="xml">
            <list string="Sync Logs" create="0" edit="0"
                  decoration-danger="status == 'error'"
                  decoration-muted="status == 'skipped'">
                <field name="create_date"/>
                <field name="name"/>
                <field name="direction"/>
                <field name="endpoint"/>
                <field name="http_method"/>
                <field name="status"/>
                <field name="http_status_code"/>
                <field name="duration_ms"/>
                <field name="odoo_model"/>
                <field name="odoo_id"/>
            </list>
        </field>
    </record>

    <record id="view_skyplanner_sync_log_form" model="ir.ui.view">
        <field name="name">skyplanner.sync.log.form</field>
        <field name="model">skyplanner.sync.log</field>
        <field name="arch" type="xml">
            <form string="Sync Log" create="0" edit="0">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="direction"/>
                            <field name="status"/>
                            <field name="endpoint"/>
                            <field name="http_method"/>
                            <field name="http_status_code"/>
                            <field name="duration_ms"/>
                        </group>
                        <group>
                            <field name="odoo_model"/>
                            <field name="odoo_id"/>
                            <field name="external_id"/>
                            <field name="create_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Request">
                            <field name="payload" widget="ace"/>
                        </page>
                        <page string="Response">
                            <field name="response" widget="ace"/>
                        </page>
                        <page string="Error" invisible="not error_message">
                            <field name="error_message" widget="text"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_skyplanner_sync_log" model="ir.actions.act_window">
        <field name="name">Sync Logs</field>
        <field name="res_model">skyplanner.sync.log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
