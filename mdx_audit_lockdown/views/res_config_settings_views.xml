<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record id="view_res_config_settings_audit" model="ir.ui.view">
      <field name="name">res.config.settings.audit</field>
      <field name="model">res.config.settings</field>
      <field name="inherit_id" ref="base.res_config_settings_view_form"/>
      <field name="arch" type="xml">
        <xpath expr="//form" position="inside">
          <app name="mdx_audit" string="Audit" groups="mdx_audit_lockdown.group_audit_admin">
            <block title="Audit Logs Access" name="mdx_audit_block">
              <setting id="audit_users_doc">
                <div class="o_setting_right_pane">
                  <div class="text-muted">
                    Manage which users can access audit logs and rules. Use the “Can View Audit Logs” checkbox on the user.
                  </div>
                </div>
              </setting>
            </block>
          </app>
        </xpath>
      </field>
    </record>
  </data>
</odoo>