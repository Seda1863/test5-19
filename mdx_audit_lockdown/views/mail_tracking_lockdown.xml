<odoo>
  <data>

    <!-- Hide the technical menu: Settings > Technical > Messaging > Tracking Values -->
    <record id="mail.menu_mail_tracking_value" model="ir.ui.menu">
      <field name="group_ids" eval="[(6, 0, [ref('base.group_system')])]"/>
    </record>

    <!-- Restrict the action as well (direct URL access / action search) -->
    <record id="mail.action_view_mail_tracking_value" model="ir.actions.act_window">
      <field name="group_ids" eval="[(6, 0, [ref('base.group_system')])]"/>
    </record>

  </data>
</odoo>