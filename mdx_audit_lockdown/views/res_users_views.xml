<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record id="view_users_form_audit" model="ir.ui.view">
      <field name="name">res.users.form.audit</field>
      <field name="model">res.users</field>
      <field name="inherit_id" ref="base.view_users_form"/>
      <field name="arch" type="xml">
        <xpath expr="//field[@name='tz']" position="after">
          <field name="can_view_audit_logs" string="Can View Audit Logs"/>
        </xpath>
      </field>
    </record>
  </data>
</odoo>