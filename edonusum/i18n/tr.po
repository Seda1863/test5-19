"        <td style=\"padding-top: 5px;\">\n"
"            <p><strong>Etkinlik Detayları</strong></p>\n"
"            <ul>\n"
"                <t t-if=\"object.event_id.location\">\n"
"                    <li>Location: <t t-out=\"object.event_id.location or ''\">Bruxelles</t>\n"
