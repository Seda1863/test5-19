<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_mdx_ebelge_senaryo_list" model="ir.ui.view">
        <field name="name">mdx.ebelge.senaryo.list</field>
        <field name="model">mdx.ebelge.senaryo</field>
        <field name="arch" type="xml">
            <list string="E-Belge Senaryo">
                <field name="active"/>
                <field name="code"/>
                <field name="name"/>
                <field name="description"/>
                <field name="ebelge_turu_ids" widget="many2many_tags" />
            </list>
        </field>
    </record>

    <record id="view_mdx_ebelge_senaryo_form" model="ir.ui.view">
        <field name="name">mdx.ebelge.senaryo.form</field>
        <field name="model">mdx.ebelge.senaryo</field>
        <field name="arch" type="xml">
            <form string="E-Belge Senaryo">
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="ebelge_turu_ids" widget="many2many_tags"/>
                        <field name="active"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_mdx_ebelge_senaryo" model="ir.actions.act_window">
        <field name="name">E-Belge Senaryo</field>
        <field name="res_model">mdx.ebelge.senaryo</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_mdx_ebelge_senaryo" name="E-Belge Senaryoları" action="action_mdx_ebelge_senaryo"/>
</odoo>