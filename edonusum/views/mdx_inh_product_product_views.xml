<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_mdx_inh_product_product_form" model="ir.ui.view">
        <field name="name">mdx.inh.product.product.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product_template_form_view"/>
        <field name="arch" type="xml">
            <!-- E-Dönüşüm sekmesi: istisna kodu ürün kartında görünür -->
            <xpath expr="//form/sheet/notebook" position="inside">
                <page string="E-Dönüşüm" name="edonusum_product_page">
                    <group>
                        <group string="Vergi ve İstisna Kodları">
                            <field name="istisna_kodu"
                                   placeholder="İstisna kodunu seçin"
                                   help="Bu alanı doldurursanız, bu ürün fatura satırına eklendiğinde vergiler otomatik %0 olur."/>
                        </group>
                        <group string="GTİP / HS Kodu">
                            <field name="hs_code" placeholder="GTIP / HS kodunu girin"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>


    <record id="view_mdx_work_type_form" model="ir.ui.view">
        <field name="name">mdx.work.type.form</field>
        <field name="model">mdx.work.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="company_id" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    
    <record id="view_mdx_work_type_list" model="ir.ui.view">
        <field name="name">mdx.work.type.list</field>
        <field name="model">mdx.work.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="description"/>
                <field name="company_id" readonly="1"/>
            </list>
        </field>
    </record>
</odoo>
