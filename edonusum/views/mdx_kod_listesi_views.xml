<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_mdx_kod_listesi_list" model="ir.ui.view">
        <field name="name">mdx.kod.listesi.list</field>
        <field name="model">mdx.kod.listesi</field>
        <field name="arch" type="xml">
            <list string="Kod Listesi">
                <field name="active"/>
                <field name="ubltr_custom" widget="radio"/>
                <field name="code"/>
                <field name="name"/>
                <field name="description"/>
                <field name="liste_tipi_id"/>
                <field name="liste_alt_tipi_id"/>
                <field name="ebelge_turu_id"/>
                <field name="gelen_giden"/>
            </list>
        </field>
    </record>

    <record id="view_mdx_kod_listesi_form" model="ir.ui.view">
        <field name="name">mdx.kod.listesi.form</field>
        <field name="model">mdx.kod.listesi</field>
        <field name="arch" type="xml">
            <form string="Kod Listesi">
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="ubltr_custom"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="liste_tipi_id"/>
                        <field name="liste_alt_tipi_id"/>
                        <field name="gelen_giden" class="conditional-invisible ebelgestatu-field"/>
                        <field name="ebelge_turu_id" class="conditional-invisible ebelgestatu-field"/>
                        <field name="ebelge_turu_id"/>
                        <field name="gelen_giden"/>
                    </group>
                    <field name="sabit_kod_ids" widget="one2many_list">
                        <list string="Sabit Kodlar">
                            <field name="name"/>
                            <field name="description"/>
                            <field name="active"/>
                        </list>
                    </field>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_mdx_kod_listesi" model="ir.actions.act_window">
        <field name="name">Kod Listesi</field>
        <field name="res_model">mdx.kod.listesi</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_mdx_kod_listesi" name="Kod Listeleri" action="action_mdx_kod_listesi"/>
</odoo>