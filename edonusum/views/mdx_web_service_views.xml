<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_mdx_web_service_list" model="ir.ui.view">
        <field name="name">mdx.web.service.list</field>
        <field name="model">mdx.web.service</field>
        <field name="arch" type="xml">
            <list string="Web Servis">
                <field name="active"/>
                <field name="name"/>
                <field name="description"/>
                <field name="company_id"/>
                <field name="url"/>
                <field name="username"/>
                <field name="password"/>
            </list>
        </field>
    </record>

    <record id="view_mdx_web_service_form" model="ir.ui.view">
        <field name="name">mdx.web.service.form</field>
        <field name="model">mdx.web.service</field>
        <field name="arch" type="xml">
            <form string="Web Servis">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="company_id"/>
                        <field name="url"/>
                        <field name="username"/>
                        <field name="password"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="vkn"/>
                        <field name="erp_code"/>
                        <field name="token"/>
                        <field name="api_get_transactions"/>
                        <field name="api_put_status"/>
                    </group>
                    <group>
                        <field name="accept"/>
                        <field name="content_type"/>
                        <field name="api_post_cari"/>
                        <field name="api_get_account_plan_codes"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_mdx_web_service" model="ir.actions.act_window">
        <field name="name">Web Servis</field>
        <field name="res_model">mdx.web.service</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_mdx_web_service" name="Web Service" action="action_mdx_web_service"/>
</odoo>