<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_mdx_kod_liste_alt_tipi_list" model="ir.ui.view">
        <field name="name">mdx.kod.liste.alt.tipi.list</field>
        <field name="model">mdx.kod.liste.alt.tipi</field>
        <field name="arch" type="xml">
            <list string="Kod Listesi Alt Tipi">
                <field name="active"/>
                <field name="code"/>
                <field name="name"/>
                <field name="description"/>
                <field name="kod_liste_tipi_id"/>
            </list>
        </field>
    </record>

    <record id="view_mdx_kod_liste_alt_tipi_form" model="ir.ui.view">
        <field name="name">mdx.kod.liste.alt.tipi.form</field>
        <field name="model">mdx.kod.liste.alt.tipi</field>
        <field name="arch" type="xml">
            <form string="Kod Listesi Alt Tipi">
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="active"/>
                        <field name="kod_liste_tipi_id"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_mdx_kod_liste_alt_tipi" model="ir.actions.act_window">
        <field name="name">Kod Listesi Alt Tipi</field>
        <field name="res_model">mdx.kod.liste.alt.tipi</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_mdx_kod_liste_alt_tipi" name="Kod Listesi Alt Tipleri" action="action_mdx_kod_liste_alt_tipi"/>
</odoo>