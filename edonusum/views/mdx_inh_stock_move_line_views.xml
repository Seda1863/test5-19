                            <field name="eirsaliye_senaryo_id" placeholder="E-İrsaliye senaryosunu seçin"/>
                            <field name="irsaliye_tipi_id" placeholder="E-İrsaliye tipini seçin"/>
                            <!-- <field name="fatura_alt_tipi_id" placeholder="İrsaliye alt tipini seçin"/> -->
                            <field name="irsaliye_statu_id" placeholder="İrsaliye statüsünü seçin"/>
                            <field name="irsaliye_seri_id" placeholder="İrsaliye serisini girin"/>
                        </group>

                        <!-- E-Fatura Teknik -->
                        <group string="E-İrsaliye Teknik">
                            <field name="eirsaliye_gonderilebilir"/>                           
                            <field name="irsaliye_gonderim_hata_kodu"/>
                            <field name="irsaliye_durum_detay"/>        
                        </group>

                        <!-- Gönderim ve Ekli Belgeler -->
                        <group string="Gönderim ve Belgeler">
                            <field name="ekli_belge_id" placeholder="Ekli belgeyi seçin"/>
                            <!-- <field name="belge_gonderim_sekli" placeholder="Belge gönderim şeklini seçin"/> -->
                            <!-- <field name="fatura_xml" placeholder="Fatura XML dosyasını ekleyin"/>
