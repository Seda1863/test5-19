<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_mdx_ebelge_turu_list" model="ir.ui.view">
        <field name="name">mdx.ebelge.turu.list</field>
        <field name="model">mdx.ebelge.turu</field>
        <field name="arch" type="xml">
            <list string="E-Belge Türü">
                <field name="active"/>
                <field name="code"/>
                <field name="name"/>
                <field name="description"/>
                <field name="belge_cinsi_id"/>
                <field name="ebelge_turu_origin_id"/>
            </list>
        </field>
    </record>

    <record id="view_mdx_ebelge_turu_form" model="ir.ui.view">
        <field name="name">mdx.ebelge.turu.form</field>
        <field name="model">mdx.ebelge.turu</field>
        <field name="arch" type="xml">
            <form string="E-Belge Türü">
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="belge_cinsi_id"/>
                        <!-- xslt_attachment_id -->
                        <field name="xslt_attachment_id"/>
                        <field name="ebelge_turu_origin_id"/>
                        <field name="active"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_mdx_ebelge_turu" model="ir.actions.act_window">
        <field name="name">E-Belge Türü</field>
        <field name="res_model">mdx.ebelge.turu</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_mdx_ebelge_turu" name="E-Belge Türleri" action="action_mdx_ebelge_turu"/>
</odoo>