<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="payment_provider_form" model="ir.ui.view">
        <field name="name">payment.provider.form.inherit.sipay</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='provider_credentials']" position="after">
                <group name="sipay_credentials" invisible="code != 'sipay'">
                    <field name="sipay_merchant_key" password="True"/>
                    <field name="sipay_app_id"/>
                    <field name="sipay_app_secret" password="True"/>
                    <field name="sipay_merchant_id"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
