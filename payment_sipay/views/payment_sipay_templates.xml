<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="sipay_inline_form" name="Sipay Inline Form">
        <div t-attf-id="sipay-container-#{payment_option_id}" data-sipay-container="true" class="o_sipay_form">
            <div class="row">
                <div class="col-lg-12">
                    <div class="form-group">
                        <label for="o_sipay_cc_holder_name">Kart Üzerindeki İsim</label>
                        <input type="text" t-attf-id="o_sipay_cc_holder_name_#{payment_option_id}" class="form-control o_sipay_cc_holder_name" placeholder="Ad Soyad" required="required"/>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-lg-12">
                    <div class="form-group">
                        <label for="o_sipay_cc_no">Kart Numarası</label>
                        <input type="text" t-attf-id="o_sipay_cc_no_#{payment_option_id}" class="form-control o_sipay_cc_no" placeholder="1234 5678 9012 3456" maxlength="19" required="required"/>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-lg-4">
                    <div class="form-group">
                        <label for="o_sipay_expiry_month">Son Kullanma Tarihi</label>
                        <div class="input-group">
                            <select t-attf-id="o_sipay_expiry_month_#{payment_option_id}" class="form-control o_sipay_expiry_month" required="required">
                                <option value="">Ay</option>
                                <option value="01">01</option>
                                <option value="02">02</option>
                                <option value="03">03</option>
                                <option value="04">04</option>
                                <option value="05">05</option>
                                <option value="06">06</option>
                                <option value="07">07</option>
                                <option value="08">08</option>
                                <option value="09">09</option>
                                <option value="10">10</option>
                                <option value="11">11</option>
                                <option value="12">12</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="form-group">
                        <label>&amp;nbsp;</label>
                        <select t-attf-id="o_sipay_expiry_year_#{payment_option_id}" class="form-control o_sipay_expiry_year" required="required">
                            <option value="">Yıl</option>
                            <t t-foreach="range(datetime.datetime.now().year, datetime.datetime.now().year + 20)" t-as="year">
                                <option t-att-value="str(year)[2:]" t-esc="year"/>
                            </t>
                        </select>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="form-group">
                        <label for="o_sipay_cvv">CVV</label>
                        <input type="text" t-attf-id="o_sipay_cvv_#{payment_option_id}" class="form-control o_sipay_cvv" placeholder="123" maxlength="4" required="required"/>
                    </div>
                </div>
            </div>
            <div class="row" t-if="installments_enabled">
                <div class="col-lg-12">
                    <div class="form-group">
                        <label for="o_sipay_installments">Taksit</label>
                        <select t-attf-id="o_sipay_installments_#{payment_option_id}" class="form-control o_sipay_installments">
                            <option value="1">Tek Çekim</option>
                            <option value="2">2 Taksit</option>
                            <option value="3">3 Taksit</option>
                            <option value="6">6 Taksit</option>
                            <option value="9">9 Taksit</option>
                            <option value="12">12 Taksit</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>
    </template>
</odoo>