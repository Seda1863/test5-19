<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- sale.order form — Entegra alanları -->
    <record id="view_sale_order_entegra_form" model="ir.ui.view">
        <field name="name">sale.order.entegra.form</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Sipariş başlığına pazaryeri badge -->
            <field name="name" position="after">
                <field name="entegra_supplier"
                       invisible="not is_entegra_order"
                       widget="badge"
                       decoration-info="entegra_supplier != ''"
                       nolabel="1"/>
                <field name="entegra_order_number"
                       invisible="not is_entegra_order"
                       nolabel="1"
                       string="Pazaryeri Sipariş No"/>
            </field>

            <!-- Stat buton alanına kargo push butonu -->
            <div name="button_box" position="inside">
                <button name="action_push_shipment_to_entegra"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-truck"
                        invisible="not is_entegra_order">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Kargo Bildir</span>
                    </div>
                </button>
            </div>

            <!-- Diğer bilgiler sekmesine Entegra tab'ı -->
            <page name="other_information" position="after">
                <page string="Entegra" invisible="not is_entegra_order">
                    <group>
                        <group string="Pazaryeri Bilgileri">
                            <field name="entegra_order_id" readonly="1"/>
                            <field name="entegra_order_number" readonly="1"/>
                            <field name="entegra_supplier" readonly="1"/>
                            <field name="entegra_status_label" readonly="1"/>
                            <field name="entegra_sync_status" readonly="1"/>
                            <field name="entegra_backend_id" readonly="1"/>
                        </group>
                        <group string="Kargo">
                            <field name="entegra_cargo_company"/>
                            <field name="entegra_cargo_code"/>
                        </group>
                    </group>
                    <group string="Pazaryeri Detayları" invisible="not entegra_marketplace_note">
                        <field name="entegra_marketplace_note" nolabel="1" readonly="1"/>
                    </group>
                </page>
            </page>

            <!-- Invisible helper field -->
            <field name="state" position="after">
                <field name="is_entegra_order" invisible="True"/>
            </field>

        </field>
    </record>

    <!-- sale.order list — pazaryeri kolonu -->
    <record id="view_sale_order_entegra_list" model="ir.ui.view">
        <field name="name">sale.order.entegra.list</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_quotation_tree"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="entegra_supplier" optional="show" string="Pazaryeri"/>
                <field name="entegra_order_number" optional="show" string="Pazaryeri No"/>
            </field>
        </field>
    </record>

    <!-- Order Import Wizard View -->
    <record id="view_entegra_order_import_wizard_form" model="ir.ui.view">
        <field name="name">entegra.order.import.wizard.form</field>
        <field name="model">entegra.order.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Entegra Sipariş Import">

                <group invisible="state == 'done'">
                    <group string="Filtreler">
                        <field name="backend_id"/>
                        <field name="supplier"/>
                        <field name="date_from"/>
                    </group>
                    <group string="Seçenekler">
                        <field name="import_all"/>
                    </group>
                </group>

                <!-- Sonuç -->
                <group invisible="state != 'done'">
                    <group string="Sonuç">
                        <field name="result_imported" string="Import Edilen"/>
                        <field name="result_skipped"  string="Atlanan"/>
                        <field name="result_errors"   string="Hata Sayısı"/>
                    </group>
                    <group string="Detaylar" invisible="result_errors == 0">
                        <field name="result_details" nolabel="1" widget="text"/>
                    </group>
                </group>

                <footer invisible="state == 'done'">
                    <button name="action_import"
                            string="Siparişleri Import Et"
                            type="object"
                            class="btn-primary"/>
                    <button string="Vazgeç" class="btn-secondary" special="cancel"/>
                </footer>
                <footer invisible="state != 'done'">
                    <button string="Kapat" class="btn-primary" special="cancel"/>
                </footer>

            </form>
        </field>
    </record>

    <!-- Order Import Action -->
    <record id="action_entegra_order_import_wizard" model="ir.actions.act_window">
        <field name="name">Entegra Sipariş Import</field>
        <field name="res_model">entegra.order.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
