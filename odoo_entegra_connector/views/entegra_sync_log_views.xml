<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_entegra_sync_log_tree" model="ir.ui.view">
        <field name="name">entegra.sync.log.list</field>
        <field name="model">entegra.sync.log</field>
        <field name="arch" type="xml">
            <list string="Sync Logları"
                  decoration-danger="status == 'error'"
                  decoration-warning="status == 'warning'"
                  decoration-success="status == 'success'">
                <field name="create_date"/>
                <field name="backend_id"/>
                <field name="operation"/>
                <field name="model_name"/>
                <field name="record_name"/>
                <field name="entegra_ref"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'success'"
                       decoration-warning="status == 'warning'"
                       decoration-danger="status == 'error'"/>
                <field name="duration_ms"/>
                <field name="error_message" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_entegra_sync_log_form" model="ir.ui.view">
        <field name="name">entegra.sync.log.form</field>
        <field name="model">entegra.sync.log</field>
        <field name="arch" type="xml">
            <form string="Sync Log Detayı" create="false" edit="false">
                <sheet>
                    <group>
                        <group>
                            <field name="backend_id"/>
                            <field name="operation"/>
                            <field name="status" widget="badge"/>
                            <field name="create_date"/>
                            <field name="duration_ms"/>
                        </group>
                        <group>
                            <field name="model_name"/>
                            <field name="record_id"/>
                            <field name="record_name"/>
                            <field name="entegra_ref"/>
                        </group>
                    </group>
                    <group string="Hata" invisible="status != 'error'">
                        <field name="error_message" nolabel="1"/>
                    </group>
                    <group string="İstek Verisi">
                        <field name="request_data" nolabel="1" widget="text"/>
                    </group>
                    <group string="Yanıt Verisi">
                        <field name="response_data" nolabel="1" widget="text"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_entegra_sync_log_search" model="ir.ui.view">
        <field name="name">entegra.sync.log.search</field>
        <field name="model">entegra.sync.log</field>
        <field name="arch" type="xml">
            <search string="Sync Log Ara">
                <field name="operation"/>
                <field name="record_name"/>
                <field name="entegra_ref"/>
                <filter name="filter_error" string="Hatalar" domain="[('status', '=', 'error')]"/>
                <filter name="filter_success" string="Başarılı" domain="[('status', '=', 'success')]"/>
                <filter name="filter_today" string="Bugün"
                        domain="[('create_date', '&gt;=', context_today().strftime('%Y-%m-%d 00:00:00'))]"/>
                <group expand="0" string="Grupla">
                    <filter name="group_by_operation" string="İşlem" context="{'group_by': 'operation'}"/>
                    <filter name="group_by_status" string="Durum" context="{'group_by': 'status'}"/>
                    <filter name="group_by_backend" string="Backend" context="{'group_by': 'backend_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_entegra_sync_log" model="ir.actions.act_window">
        <field name="name">Sync Logları</field>
        <field name="res_model">entegra.sync.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_entegra_sync_log_search"/>
    </record>

</odoo>
