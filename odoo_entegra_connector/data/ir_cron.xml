<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Token Proaktif Yenileme — Günde 1x (token ban riskini sıfırlar) -->
        <record id="cron_entegra_refresh_token" model="ir.cron">
            <field name="name">Entegra: Token Yenile</field>
            <field name="model_id" ref="model_entegra_backend"/>
            <field name="state">code</field>
            <field name="code">model._cron_refresh_tokens()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
            <field name="priority">5</field>
        </record>

        <!-- Sipariş Import — 15 dakikada 1 -->
        <record id="cron_entegra_import_orders" model="ir.cron">
            <field name="name">Entegra: Sipariş Import</field>
            <field name="model_id" ref="model_entegra_order_import"/>
            <field name="state">code</field>
            <field name="code">model._cron_import_orders()</field>
            <field name="interval_number">15</field>
            <field name="interval_type">minutes</field>

            <field name="active">True</field>
            <field name="priority">10</field>
        </record>

        <!-- Stok Güncelleme — 30 dakikada 1 -->
        <record id="cron_entegra_push_stock" model="ir.cron">
            <field name="name">Entegra: Stok Güncelle</field>
            <field name="model_id" ref="model_entegra_product_push"/>
            <field name="state">code</field>
            <field name="code">model._cron_push_stock()</field>
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>

            <field name="active">True</field>
            <field name="priority">10</field>
        </record>

        <!-- Fiyat Güncelleme — Saatte 1 -->
        <record id="cron_entegra_push_prices" model="ir.cron">
            <field name="name">Entegra: Fiyat Güncelle</field>
            <field name="model_id" ref="model_entegra_product_push"/>
            <field name="state">code</field>
            <field name="code">model._cron_push_prices()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>

            <field name="active">True</field>
            <field name="priority">10</field>
        </record>

    </data>
</odoo>
