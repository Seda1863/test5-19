<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_mdx_mutabakat" model="ir.ui.view">
        <field name="name">res.partner.form.mdx.mutabakat</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="%(action_mdx_mutabakat)d" type="action"
                    class="oe_stat_button" icon="fa-handshake-o"
                    context="{'search_default_partner_id': id, 'default_partner_id': id}">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">Mutabakatlar</span>
                    </div>
                </button>
            </div>
        </field>
    </record>
</odoo>