UI_Contract --> UI_Batch : contract selects bank rules
UI_Partner --> UI_Invoice : customer eligibility & limit
UI_Invoice --> UI_Batch : send invoice to DBS
UI_Batch --> UI_Rejected : rejected rows
UI_Rejected --> UI_Partner : suspend customer profile

note bottom of UI_Batch
Batch screen is the operational center:
- export CSV
- import ACK
- inspect line states
- trace logs
end note

@enduml

@startuml
' ------------------------------------------------------------
' Diagram 3: End-to-end flow
' ------------------------------------------------------------
skinparam shadowing false

title Odoo 18 TR DBS - Operational Flow (MVP)

actor "Finance User" as User
participant "account.move\n(Customer Invoice)" as Inv
participant "dbs.batch" as Batch
participant "dbs.adapter.*" as Adapter
participant "Bank Channel" as Bank
participant "account.bank.statement.line" as StLine
participant "Reconciliation" as Recon

User -> Inv : Click "DBS'ye Gonder"
Inv -> Batch : _add_invoices(moves)
Batch -> Batch : validations + dbs_line_ref generation

User -> Batch : action_send()
Batch -> Adapter : export_batch(batch)
Adapter -> Bank : send payload (file/api/sftp)
Adapter --> Batch : export_file + bank_reference
Batch -> Batch : state = sent

User -> Batch : upload ACK file + action_import_ack()
Batch -> Adapter : import_ack(contract, content)
Adapter --> Batch : line statuses (accepted/rejected/settled)
Batch -> Batch : state = ack/settled

Bank -> StLine : payment statement imported
StLine -> StLine : _extract_dbs_ref()
StLine -> Batch : find dbs.batch.line by dbs_line_ref
StLine -> Recon : create payment + reconcile invoice
StLine -> Batch : dbs.batch.line.state = settled

@enduml
