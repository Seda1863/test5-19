@startuml
' ------------------------------------------------------------
' Diagram 1: Module dependencies
' ------------------------------------------------------------
left to right direction
skinparam componentStyle rectangle
skinparam shadowing false

title Odoo 18 TR DBS - Module Dependency Map

package "Odoo Standard Modules" {
  [account]
  [mail]
}

package "DBS Modules" {
  [account_dbs_tr]
  [account_dbs_tr_stubbank]
}

package "External Bank Layer" {
  [Bank API / SFTP / File Channel]
}

[account_dbs_tr] --> [account] : depends
[account_dbs_tr] --> [mail] : depends
[account_dbs_tr_stubbank] --> [account_dbs_tr] : depends

[account_dbs_tr] --> [Bank API / SFTP / File Channel] : adapter pattern
[account_dbs_tr_stubbank] --> [Bank API / SFTP / File Channel] : concrete adapter

note bottom of [account_dbs_tr]
Core responsibilities:
- dbs.contract / dbs.batch / dbs.batch.line
- ACK import + batch send
- statement auto-match
- partner and invoice extensions
end note

@enduml

@startuml
' ------------------------------------------------------------
' Diagram 2: Core data model relationships
' ------------------------------------------------------------
skinparam classAttributeIconSize 0
skinparam shadowing false

title Odoo 18 TR DBS - Core Data Model

class "res.partner" as Partner {
  +dbs_enabled: Boolean
  +dbs_status: active|suspended|closed
  +dbs_contract_id: Many2one(dbs.contract)
  +dbs_customer_code: Char
  +dbs_limit: Monetary
  +dbs_limit_available: Monetary(compute)
}

class "dbs.contract" as Contract {
  +name: Char
  +company_id: Many2one(res.company)
  +currency_id: Many2one(res.currency)
  +bank_partner_id: Many2one(res.partner)
  +settlement_bank_journal_id: Many2one(account.journal)
  +suspense_account_id: Many2one(account.account)
  +integration_type: manual|sftp|api
  +adapter_code: Char
  +active: Boolean
}

class "dbs.batch" as Batch {
  +name: Sequence(DBSB/YYYY/NNNN)
  +date: Date
  +contract_id: Many2one(dbs.contract)
  +state: draft|sent|ack|settled|closed|cancel
  +bank_reference: Char
  +export_file: Binary
  +ack_file: Binary
}

class "dbs.batch.line" as BatchLine {
  +dbs_line_ref: Char(unique)
  +move_id: Many2one(account.move)
  +partner_id: Many2one(res.partner)
  +partner_customer_code: Char
  +due_date: Date
  +amount: Monetary
  +state: to_send|sent|accepted|rejected|settled|returned
  +reject_code: Char
  +last_message: Char
  +retry_count: Integer
  +last_retry_at: Datetime
  +warned_at: Datetime
  +action_retry_rejected()
  +action_warn_customer()
  +action_suspend_customer_profile()
}

class "account.move" as Move {
  +dbs_state: Selection(compute)
  +dbs_line_ref: Char(compute)
  +dbs_line_count: Integer(compute)
  +dbs_history: Text(compute)
  +action_send_to_dbs()
  +action_view_dbs_lines()
}

class "account.bank.statement.line" as StLine {
  +dbs_batch_line_id: Many2one(dbs.batch.line)
  +_dbs_try_match()
}

class "dbs.message.log" as MsgLog {
  +level: info|warning|error
  +model: Char
  +res_id: Integer
  +message: Text
}

Contract "1" <-- "0..*" Partner : dbs_contract_id
Contract "1" <-- "0..*" Batch : contract_id
Batch "1" <-- "1..*" BatchLine : line_ids
Partner "1" <-- "0..*" BatchLine : partner_id
Move "1" <-- "0..*" BatchLine : move_id
BatchLine "0..1" --> "0..*" StLine : matched by ref
Batch "1" <-- "0..*" MsgLog : logs
Contract "1" <-- "0..*" MsgLog : logs

@enduml

