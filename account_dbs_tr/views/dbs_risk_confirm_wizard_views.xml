<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dbs_risk_confirm_wizard_form" model="ir.ui.view">
        <field name="name">dbs.risk.confirm.wizard.form</field>
        <field name="model">dbs.risk.confirm.wizard</field>
        <field name="arch" type="xml">
            <form string="DBS Risk Uyarisi" create="0" edit="0" delete="0">
                <group>
                    <field name="message" nolabel="1" readonly="1" widget="text"/>
                </group>
                <group>
                    <group>
                        <field name="partner_id" readonly="1"/>
                        <field name="contract_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="limit_amount" readonly="1"/>
                        <field name="available_amount" readonly="1"/>
                        <field name="required_amount" readonly="1"/>
                        <field name="over_amount" readonly="1"/>
                    </group>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Devam Et" class="btn-primary"/>
                    <button name="action_cancel" type="object" string="Iptal" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_dbs_risk_confirm_wizard" model="ir.actions.act_window">
        <field name="name">DBS Risk Uyarisi</field>
        <field name="res_model">dbs.risk.confirm.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_dbs_risk_confirm_wizard_form"/>
    </record>
</odoo>
