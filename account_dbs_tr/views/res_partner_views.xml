<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_tree_dbs_customers" model="ir.ui.view">
        <field name="name">res.partner.tree.dbs.customers</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <list string="DBS Musteriler">
                <field name="name"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="dbs_status" widget="badge"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <!-- Standart partner formuna DBS tabı (readonly özet) -->
    <record id="view_partner_form_dbs_inherit" model="ir.ui.view">
        <field name="name">res.partner.form.dbs.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="inside">
                <page string="DBS">
                    <field name="dbs_contract_id" invisible="1"/>
                    <group>
                        <group>
                            <field name="dbs_enabled"/>
                            <field name="dbs_status"/>
                            <field name="dbs_risk_control"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- DBS Müşteriler listesinden açılan özel form: DBS bilgileri direkt görünür -->
    <record id="view_partner_form_dbs_customers" model="ir.ui.view">
        <field name="name">res.partner.form.dbs.customers</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <form string="DBS Müşteri">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" name="action_open_dbs_contract" type="object" icon="fa-link" invisible="not dbs_contract_id">
                            <field name="dbs_contract_count" string="DBS Sözleşmesi" widget="statinfo"/>
                        </button>
                        <button class="oe_stat_button" name="action_open_dbs_batches" type="object" icon="fa-list" invisible="dbs_batch_count == 0">
                            <field name="dbs_batch_count" string="DBS Toplu İşlem" widget="statinfo"/>
                        </button>
                        <button class="oe_stat_button" name="action_open_dbs_invoices" type="object" icon="fa-files-o" invisible="dbs_invoice_count == 0">
                            <field name="dbs_invoice_count" string="DBS Faturaları" widget="statinfo"/>
                        </button>
                        <button class="oe_stat_button" name="action_print_dbs_report" type="object" icon="fa-download">
                            <span class="o_stat_text">DBS Raporu</span>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="DBS Durumu">
                            <field name="dbs_enabled"/>
                            <field name="dbs_status"/>
                            <field name="dbs_risk_control"/>
                        </group>
                        <group string="Limit Bilgisi">
                            <field name="dbs_limit" readonly="1"/>
                            <field name="dbs_used_amount" readonly="1"/>
                            <field name="dbs_limit_available" readonly="1"/>
                            <field name="dbs_over_amount" readonly="1" invisible="dbs_over_amount == 0"/>
                        </group>
                    </group>
                    <group>
                        <group string="İletişim">
                            <field name="phone" readonly="1"/>
                            <field name="mobile" readonly="1"/>
                            <field name="email" readonly="1"/>
                        </group>
                        <group string="DBS Sözleşme">
                            <field name="dbs_contract_id" readonly="1"/>
                            <field name="dbs_bank_id" readonly="1"/>
                            <field name="dbs_bank_account_id" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_dbs_customers" model="ir.actions.act_window">
        <field name="name">DBS Musteriler</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('dbs_enabled', '=', True)]</field>
    </record>

    <record id="action_dbs_customers_tree_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_partner_tree_dbs_customers"/>
        <field name="act_window_id" ref="action_dbs_customers"/>
    </record>

    <record id="action_dbs_customers_form_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_partner_form_dbs_customers"/>
        <field name="act_window_id" ref="action_dbs_customers"/>
    </record>

    <record id="view_partner_tree_dbs_report_summary" model="ir.ui.view">
        <field name="name">res.partner.tree.dbs.report.summary</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <list string="DBS Rapor Ozeti">
                <field name="name"/>
                <field name="dbs_status" widget="badge"/>
                <field name="dbs_customer_code"/>
                <field name="dbs_contract_id"/>
                <field name="dbs_risk_control"/>
                <field name="dbs_limit"/>
                <field name="dbs_used_amount"/>
                <field name="dbs_limit_available"/>
                <field name="dbs_over_amount"/>
                <field name="dbs_bank_id"/>
                <field name="dbs_settlement_bank_journal_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_partner_form_dbs_report_summary" model="ir.ui.view">
        <field name="name">res.partner.form.dbs.report.summary</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <form string="DBS Rapor Ozeti">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" name="action_open_dbs_contract" type="object" icon="fa-link" invisible="not dbs_contract_id">
                            <field name="dbs_contract_count" string="DBS Sozlesmesi" widget="statinfo"/>
                        </button>
                        <button class="oe_stat_button" name="action_open_dbs_batches" type="object" icon="fa-list" invisible="dbs_batch_count == 0">
                            <field name="dbs_batch_count" string="DBS Toplu Islem" widget="statinfo"/>
                        </button>
                        <button class="oe_stat_button" name="action_open_dbs_invoices" type="object" icon="fa-files-o" invisible="dbs_invoice_count == 0">
                            <field name="dbs_invoice_count" string="DBS Faturalari" widget="statinfo"/>
                        </button>
                        <button class="oe_stat_button" name="action_print_dbs_report" type="object" icon="fa-download">
                            <span class="o_stat_text">DBS Raporu Indir</span>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="DBS Durumu">
                            <field name="dbs_enabled" readonly="1"/>
                            <field name="dbs_status" readonly="1" widget="badge"/>
                            <field name="dbs_risk_control" readonly="1"/>
                        </group>
                        <group string="Limit Bilgisi">
                            <field name="dbs_limit" readonly="1"/>
                            <field name="dbs_used_amount" readonly="1"/>
                            <field name="dbs_limit_available" readonly="1"/>
                            <field name="dbs_over_amount" readonly="1" invisible="dbs_over_amount == 0"
                                decoration-danger="dbs_over_amount &gt; 0"/>
                        </group>
                    </group>
                    <group>
                        <group string="Sozlesme Bilgisi">
                            <field name="dbs_contract_id" readonly="1"/>
                            <field name="dbs_bank_id" readonly="1"/>
                            <field name="dbs_bank_account_id" readonly="1"/>
                            <field name="dbs_settlement_bank_journal_id" readonly="1"/>
                        </group>
                        <group string="Iletisim">
                            <field name="phone" readonly="1"/>
                            <field name="mobile" readonly="1"/>
                            <field name="email" readonly="1"/>
                            <field name="company_id" readonly="1" groups="base.group_multi_company"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_dbs_report_summary" model="ir.actions.act_window">
        <field name="name">DBS Rapor Ozeti</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('dbs_enabled', '=', True)]</field>
    </record>

    <record id="action_dbs_report_summary_tree_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_partner_tree_dbs_report_summary"/>
        <field name="act_window_id" ref="action_dbs_report_summary"/>
    </record>

    <record id="action_dbs_report_summary_form_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_partner_form_dbs_report_summary"/>
        <field name="act_window_id" ref="action_dbs_report_summary"/>
    </record>
</odoo>
