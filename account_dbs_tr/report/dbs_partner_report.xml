<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_dbs_partner" model="ir.actions.report">
        <field name="name">DBS Raporu</field>
        <field name="model">res.partner</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">account_dbs_tr.report_dbs_partner_document</field>
        <field name="report_file">account_dbs_tr.report_dbs_partner_document</field>
        <field name="print_report_name">'DBS_Raporu_%s' % (object.name)</field>
    </record>

    <template id="report_dbs_partner_document">
        <t t-call="web.external_layout">
            <t t-foreach="docs" t-as="partner">
                <t t-set="payload" t-value="payloads.get(partner.id)"/>
                <main>
                <div class="page">
                    <h2>DBS Durum Raporu</h2>
                    <p><strong>Cari:</strong> <span t-esc="partner.display_name"/></p>
                    <p><strong>Şirket:</strong> <span t-esc="partner.company_id.display_name or '-'"/></p>
                    <p><strong>DBS Özeti:</strong></p>
                    <pre style="white-space: pre-wrap; font-family: inherit;"><t t-esc="partner.dbs_status_summary or '-'"/></pre>

                    <h3>Temel Bilgiler</h3>
                    <table class="table table-sm o_main_table">
                        <tbody>
                            <tr>
                                <td><strong>DBS Aktif</strong></td>
                                <td><span t-esc="'Evet' if partner.dbs_enabled else 'Hayır'"/></td>
                                <td><strong>DBS Durumu</strong></td>
                                <td><span t-esc="dict(partner._fields['dbs_status'].selection).get(partner.dbs_status, '-')"/></td>
                            </tr>
                            <tr>
                                <td><strong>Risk Kontrol</strong></td>
                                <td><span t-esc="dict(partner._fields['dbs_risk_control'].selection).get(partner.dbs_risk_control, '-')"/></td>
                                <td><strong>Müşteri Kodu</strong></td>
                                <td><span t-esc="partner.dbs_customer_code or '-'"/></td>
                            </tr>
                            <tr>
                                <td><strong>Limit</strong></td>
                                <td><span t-esc="'{:,.2f}'.format(partner.dbs_limit or 0.0)"/></td>
                                <td><strong>Kullanılan Limit</strong></td>
                                <td><span t-esc="'{:,.2f}'.format(partner.dbs_used_amount or 0.0)"/></td>
                            </tr>
                            <tr>
                                <td><strong>Kullanılabilir Limit</strong></td>
                                <td><span t-esc="'{:,.2f}'.format(partner.dbs_limit_available or 0.0)"/></td>
                                <td><strong>Limit Aşımı</strong></td>
                                <td><span t-esc="'{:,.2f}'.format(partner.dbs_over_amount or 0.0)"/></td>
                            </tr>
                        </tbody>
                    </table>

                    <h3>Banka Bilgisi</h3>
                    <table class="table table-sm o_main_table">
                        <tbody>
                            <tr>
                                <td><strong>Banka</strong></td>
                                <td><span t-esc="payload['bank_name'] if payload else '-'"/></td>
                                <td><strong>IBAN</strong></td>
                                <td><span t-esc="payload['bank_account'] if payload else '-'"/></td>
                            </tr>
                            <tr>
                                <td><strong>Tahsilat Yevmiyesi</strong></td>
                                <td><span t-esc="payload['journal_name'] if payload else '-'"/></td>
                                <td><strong>DBS Sözleşmesi</strong></td>
                                <td><span t-esc="payload['contract'].display_name if payload and payload['contract'] else '-'"/></td>
                            </tr>
                        </tbody>
                    </table>

                    <h3>Sayısal Özet</h3>
                    <table class="table table-sm o_main_table">
                        <tbody>
                            <tr>
                                <td><strong>Sözleşme Sayısı</strong></td>
                                <td><span t-esc="partner.dbs_contract_count"/></td>
                                <td><strong>Toplu İşlem Sayısı</strong></td>
                                <td><span t-esc="partner.dbs_batch_count"/></td>
                            </tr>
                            <tr>
                                <td><strong>Satır Sayısı</strong></td>
                                <td><span t-esc="partner.dbs_line_count"/></td>
                                <td><strong>Fatura Sayısı</strong></td>
                                <td><span t-esc="partner.dbs_invoice_count"/></td>
                            </tr>
                        </tbody>
                    </table>

                    <t t-if="payload and payload['batches']">
                        <h3>Son DBS Toplu İşlemler</h3>
                        <table class="table table-sm table-bordered">
                            <thead>
                                <tr>
                                    <th>No</th>
                                    <th>Tarih</th>
                                    <th>Durum</th>
                                    <th>Satır</th>
                                    <th>Toplam</th>
                                    <th>Banka Referansı</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="payload['batches']" t-as="batch">
                                    <tr>
                                        <td><span t-esc="batch.name"/></td>
                                        <td><span t-esc="batch.date"/></td>
                                        <td><span t-esc="batch.state"/></td>
                                        <td><span t-esc="batch.line_count"/></td>
                                        <td><span t-esc="'{:,.2f}'.format(batch.total_amount or 0.0)"/></td>
                                        <td><span t-esc="batch.bank_reference or '-'"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>

                    <t t-if="payload and payload['lines']">
                        <h3>Son DBS Satırları</h3>
                        <table class="table table-sm table-bordered">
                            <thead>
                                <tr>
                                    <th>Satır Ref</th>
                                    <th>Fatura</th>
                                    <th>Durum</th>
                                    <th>Tutar</th>
                                    <th>Ret Kodu</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="payload['lines']" t-as="line">
                                    <tr>
                                        <td><span t-esc="line.dbs_line_ref or '-'"/></td>
                                        <td><span t-esc="line.move_id.display_name or '-'"/></td>
                                        <td><span t-esc="line.state"/></td>
                                        <td><span t-esc="'{:,.2f}'.format(line.amount or 0.0)"/></td>
                                        <td><span t-esc="line.reject_code or '-'"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>
                </div>
                </main>
            </t>
        </t>
    </template>

</odoo>
