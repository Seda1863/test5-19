<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="seq_dbs_contract" model="ir.sequence">
        <field name="name">DBS Contract</field>
        <field name="code">dbs.contract</field>
        <field name="prefix">DBSC/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_dbs_batch" model="ir.sequence">
        <field name="name">DBS Batch</field>
        <field name="code">dbs.batch</field>
        <field name="prefix">DBSB/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
